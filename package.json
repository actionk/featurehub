{
  "name": "feature-hub",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop app for managing work features with linked Claude Code sessions",
  "license": "MIT",
  "author": "Little Brush Games",
  "repository": {
    "type": "git",
    "url": "https://github.com/LittleBrushGames/FeatureHub"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:cli": "cd src-tauri && cargo build --bin fh --bin fh-mcp && cd .. && node scripts/install-cli.mjs",
    "rebuild:macos": "bash scripts/rebuild-macos.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "install:github-prs": "node scripts/install-github-prs.mjs"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-fs": "^2.2.0",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "chart.js": "^4.5.1",
    "dompurify": "^3.4.0",
    "marked": "^15.0.0",
    "mermaid": "^11.13.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/dompurify": "^3.2.0",
    "jsdom": "^29.0.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.2"
  }
}
